# Copy to .env and fill in real values.

# Server
NODE_ENV=development
PORT=5000

# MongoDB (required)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Firebase Admin (required for token verification)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Full private key including -----BEGIN/END-----; use \n for newlines if on one line (Windows)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<your-private-key-here>\n-----END PRIVATE KEY-----\n"

# Seed: create OWNER in Firebase Auth first, then set these
OWNER_EMAIL=owner@factory.com
OWNER_FIREBASE_UID=firebase-uid-of-owner-user

# CORS: comma-separated origins (no trailing slash)
CORS_ORIGINS=http://localhost:5173
ALLOW_VERCEL_PREVIEWS=false

# Optional: public API URL (e.g. for PDF links in production)
API_BASE_URL=http://localhost:5000

# Rate limiting (optional)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

